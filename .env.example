# Optional anonymous telemetry (disabled unless BOTH this build config AND the
# in-app opt-in are set). These are Vite build-time vars: they are inlined at
# `npm run build`, so they must be present in the *build* environment —
# Vercel Project → Settings → Environment Variables, and the Android build shell.
# They are NOT read at runtime and NOT in .env.production, so a deploy without them
# ships with analytics permanently off (isAnalyticsConfigured() === false).
# The webhook (e.g. a Make.com custom webhook) must also allow a cross-origin POST
# from the app origin — return CORS headers permitting `content-type` and the
# `x-make-apikey` header — or browser (web/PWA) requests fail the CORS preflight.
VITE_QS_ANALYTICS_ENABLED=false
VITE_QS_ANALYTICS_WEBHOOK_URL=https://example.invalid/questshelf-analytics
VITE_QS_ANALYTICS_KEY=replace-with-alpha-analytics-key
# Provider API keys are user-provided in the app and forwarded statelessly through the integration proxy.
# Do not configure server-side STEAM/ITAD/RAWG/STEAMGRIDDB keys.


# Optional HTTPS backend/proxy base URLs for production web and Capacitor Android builds.
# Leave unset for Vite dev, which uses vite.config.ts /api/steam and /api/steam-store proxies.
# Do not point Android production builds at localhost; localhost is the Android device itself.
# Example values if your backend mirrors the Vite proxy paths:
# VITE_STEAM_API_BASE_URL=https://your-api.example.com/api/steam/IPlayerService
# VITE_STEAM_STATS_API_BASE_URL=https://your-api.example.com/api/steam/ISteamUserStats
# VITE_STEAM_USER_API_BASE_URL=https://your-api.example.com/api/steam/ISteamUser
# VITE_STEAM_STORE_BASE_URL=https://your-api.example.com/api/steam-store

# Production integration proxy routing (Android should use the absolute Vercel URL).
# VITE_INTEGRATIONS_PROXY_BASE_URL=https://getquestory.vercel.app/api/integrations
# VITE_STEAM_PROXY_BASE_URL=https://getquestory.vercel.app/api/integrations/steam
